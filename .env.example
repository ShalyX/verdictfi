# Optional live integrations. Demo mode works without secrets.
# Do not commit real values.
SOSOVALUE_API_KEY=
SOSOVALUE_API_BASE=https://openapi.sosovalue.com/openapi/v1
SOSOVALUE_API_TIMEOUT_MS=8000
SOSOVALUE_API_RETRIES=1
SODEX_TESTNET_API_KEY=
SODEX_TESTNET_PRIVATE_KEY=
# Set true to submit approved/cautioned orders to a configured SoDEX testnet endpoint.
SODEX_TESTNET_SUBMIT_ENABLED=false
SODEX_TESTNET_SUBMIT_URL=
OPENAI_API_KEY=
VERDICTFI_DB_PATH=.data/verdictfi.sqlite
VERDICTFI_RATE_LIMIT_MAX=30
VERDICTFI_RATE_LIMIT_WINDOW_MS=60000
# Set true only behind a trusted proxy that owns x-forwarded-for / x-real-ip.
VERDICTFI_TRUST_PROXY_HEADERS=false
